# Copy this to .env.local and fill in your values

# Next.js
NEXT_PUBLIC_SITE_URL=https://kmitl-fs.vercel.app

# Google Apps Script (Order Form → Google Sheets)
NEXT_PUBLIC_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Analytics
# NEXT_PUBLIC_GA_ID=your_google_analytics_id

# Headless CMS (optional - for blog)
# NEXT_PUBLIC_CMS_URL=https://your-cms.com
# CMS_API_KEY=your_cms_api_key
